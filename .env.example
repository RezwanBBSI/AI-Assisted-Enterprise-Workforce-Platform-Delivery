# Root .env — used by docker-compose.yml
# Copy this file to .env and fill in values before running docker-compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=workforce
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=workforce

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins for CORSMiddleware
ALLOWED_ORIGINS=["http://localhost","http://localhost:80"]
