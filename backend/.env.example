# Environment Variables — copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL=sqlite:///./workforce.db
# Docker / production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://workforce:workforce_secret@db:5432/workforce

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:80"]

# ── PostgreSQL (Docker Compose only) ──────────────────────────────────────────
POSTGRES_USER=workforce
POSTGRES_PASSWORD=workforce_secret
POSTGRES_DB=workforce
